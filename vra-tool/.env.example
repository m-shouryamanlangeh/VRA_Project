# Required: encrypts API keys you paste in Settings (not your Gemini key itself).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Leave blank if you add / rotate Gemini keys only in the app (Settings page).
# Optional: only used when the database has zero Gemini keys (e.g. first run before opening Settings).
GEMINI_API_KEY=
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./data/vra.db

# Hybrid mode: collectors + compact Gemini synthesis — strongly recommended to reduce
# name-collision hallucinations in PDFs vs legacy Google-search JSON mode.
USE_HYBRID_MODE=true
